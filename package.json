  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8",
    "typescript": "^5.5",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@freeside-collective/schema": "workspace:*",
    "@tanstack/react-query": "^5.95.2",
    "firebase": "^10.11.0"
  }
